# Railway environment variables — set these in Railway Dashboard
# This file is for REFERENCE only. Do NOT commit secrets to git.

# ── Required ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
DATABASE_URL=  # Auto-provided by Railway when you add PostgreSQL service

# ── CORS ──────────────────────────────────────────────────────────────────
# Add your domain(s) here once you have one
CORS_ORIGINS=https://your-app.up.railway.app,http://localhost:5173

# ── Optional (for future features) ────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY_PATH=
